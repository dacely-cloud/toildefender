{
    "name": "@dacely/toildefender",
    "version": "0.1.8",
    "type": "module",
    "description": "Modern JavaScript code protection, bytecode virtualization, and obfuscation for the Toil tech stack.",
    "author": "Dacely",
    "contributors": [
        {
            "name": "Alexander Horn",
            "url": "https://github.com/alexhorn"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dacely-cloud/toildefender.git"
    },
    "bugs": {
        "url": "https://github.com/dacely-cloud/toildefender/issues"
    },
    "homepage": "https://github.com/dacely-cloud/toildefender#readme",
    "keywords": [
        "javascript",
        "obfuscation",
        "bytecode",
        "virtual-machine",
        "code-protection",
        "toiljs",
        "dacely"
    ],
    "main": "./build/toildefender.cjs",
    "module": "./build/toildefender.js",
    "types": "./build/toildefender.d.ts",
    "exports": {
        ".": {
            "types": "./build/toildefender.d.ts",
            "import": "./build/toildefender.js",
            "require": "./build/toildefender.cjs",
            "default": "./build/toildefender.js"
        },
        "./cli": {
            "types": "./build/cli.d.ts",
            "import": "./build/cli.js",
            "require": "./build/cli.cjs",
            "default": "./build/cli.js"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "toildefender": "toildefender.js"
    },
    "scripts": {
        "build": "vite build && tsc -p tsconfig.build.json",
        "typecheck": "tsc -p tsconfig.json",
        "lint": "eslint src",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "npm run build && node --test test/*.test.js test/*.test.cjs",
        "test:firefox": "node test/firefox-smoke.mjs",
        "pack:dry": "npm pack --dry-run",
        "prepack": "npm run build"
    },
    "toildefender": {
        "mainFiles": [
            "toildefender.js"
        ]
    },
    "files": [
        "build",
        "defendjs.js",
        "toildefender.js",
        "LICENSE",
        "NOTICE.md",
        "README.md",
        "images/toildefender3.svg",
        "docs/all-modes-output.demo.js"
    ],
    "dependencies": {
        "@babel/parser": "^8.0.0",
        "escodegen": "^2.1.0",
        "escope": "^4.0.0",
        "esprima": "^4.0.1",
        "esshorten": "1.1.1",
        "estraverse": "^5.3.0",
        "expr-eval-fork": "^3.0.3",
        "lodash": "^4.18.1",
        "minimist": "^1.2.8"
    },
    "engines": {
        "node": ">=24.11.0",
        "npm": ">=10.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "AGPL-3.0",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/escodegen": "^0.0.10",
        "@types/esprima": "^4.0.6",
        "@types/estraverse": "^5.1.7",
        "@types/estree": "^1.0.9",
        "@types/lodash": "^4.17.24",
        "@types/minimist": "^1.2.5",
        "@types/node": "^26.0.0",
        "eslint": "^10.5.0",
        "playwright": "^1.61.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16"
    }
}
